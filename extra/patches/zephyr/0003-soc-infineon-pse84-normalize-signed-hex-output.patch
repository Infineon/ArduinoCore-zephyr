From 4f35d2a0e77f4f1da42d4131f70aa508a8ef1822 Mon Sep 17 00:00:00 2001
From: Arduino PSoC Edge BSP contributors
Date: Mon, 8 Jun 2026 00:00:00 +0000
Subject: [PATCH] soc: infineon: pse84: normalize signed HEX artifact path

PSE84 metadata generation creates ${KERNEL_NAME}.signed.hex, while the
shared ArduinoCore-zephyr packaging flow expects the standard Zephyr
artifact path (${KERNEL_NAME}.hex).

Copy the generated signed HEX over the default unsigned HEX output path
so downstream packagers can keep using the common artifact naming
convention without introducing board-specific handling in shared scripts.

Signed-off-by: Arduino PSoC Edge BSP contributors

diff --git a/soc/infineon/edge/pse84/pse84_metadata.cmake b/soc/infineon/edge/pse84/pse84_metadata.cmake
--- a/soc/infineon/edge/pse84/pse84_metadata.cmake
+++ b/soc/infineon/edge/pse84/pse84_metadata.cmake
@@ -24,6 +24,8 @@ function(pse84_add_metadata_secure_hex INPUT_FILE OUTPUT_FILE)
       --header-size ${header_size} --erased-val 0xff --pad-header
       --slot-size ${slot_size} --hex-addr ${header_addr}
       ${INPUT_FILE} ${OUTPUT_FILE}
+    # Preserve the standard Zephyr HEX artifact path for downstream packagers.
+    COMMAND ${CMAKE_COMMAND} -E copy_if_different ${OUTPUT_FILE} ${INPUT_FILE}
   )
   set_property(GLOBAL APPEND PROPERTY extra_post_build_byproducts ${OUTPUT_FILE})
 endfunction()
